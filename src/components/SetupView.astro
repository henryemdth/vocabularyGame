---
import SetupReadyView from "./SetupReadyView.astro";
---

<section id="view-setup" class="view">
  <div class="setup-card">
    <div class="setup-header">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
        <rect width="48" height="48" rx="12" fill="var(--green-bg)"></rect>
        <path
          d="M16 24h16M24 16v16"
          stroke="var(--green)"
          stroke-width="3"
          stroke-linecap="round"></path>
      </svg>
      <h1 class="setup-title">Vocab Flashcards</h1>
    </div>

    <div id="setup-empty" class="setup-empty">
      <p class="setup-desc">Choose a vocabulary file to get started:</p>
      <button class="upload-btn-inline" id="upload-inline-btn">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path
            d="M8 2v12M2 8h12"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
        Load JSON File
      </button>
      <button
        class="upload-btn-inline upload-btn-default"
        id="load-default-btn"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <rect
            x="2"
            y="3"
            width="12"
            height="10"
            rx="1"
            stroke="currentColor"
            stroke-width="1.5"
            fill="none"></rect>
          <path
            d="M5 3V2a1 1 0 011-1h4a1 1 0 011 1v1"
            stroke="currentColor"
            stroke-width="1.5"
            fill="none"></path>
        </svg>
        Load Sample Deck
      </button>
      <div class="json-hint">
        <p class="hint-label">Expected format:</p>
        <pre
          class="hint-code">{`{
          "apple": "manzana",
          "book": "libro"
         }`}
        </pre>
      </div>
      <p id="upload-error" class="upload-error"></p>
    </div>

    <SetupReadyView />
  </div>
</section>
