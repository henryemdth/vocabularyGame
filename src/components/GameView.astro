<section id="view-game" class="view">
  <div class="game-container">
    <div class="game-header">
      <span id="card-progress" class="card-progress">Card 1 / 10</span>
      <button id="configure-btn" class="configure-btn" aria-label="Configure">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="1.5" fill="currentColor"/>
          <path d="M8 2v2M8 12v2M2 8h2M12 8h2M3.5 3.5l1.5 1.5M11 11l1.5 1.5M3.5 12.5l1.5-1.5M11 5l1.5-1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="timer-track">
      <div id="timer-bar" class="timer-bar"></div>
    </div>

    <div class="flashcard">
      <p id="card-prompt" class="card-prompt">apple</p>
    </div>

    <div id="options-container" class="options-grid">
      <button class="option-btn">Option 1</button>
      <button class="option-btn">Option 2</button>
      <button class="option-btn">Option 3</button>
      <button class="option-btn">Option 4</button>
    </div>

    <div id="card-feedback" class="feedback"></div>

    <button id="next-btn" class="next-btn" style="display:none">
      Next
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M6 3l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>
